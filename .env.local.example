# Anthropic API – used for FAQ AI assistant
ANTHROPIC_API_KEY=sk-ant-...

# Turso (LibSQL) – serverless SQLite database
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Admin password for /admin/* routes
ADMIN_PASSWORD=changeme-strong-password

# Secret used to sign session cookies (generate with: openssl rand -base64 32)
SESSION_SECRET=your-super-secret-session-key-at-least-32-chars
